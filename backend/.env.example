PORT=8080
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<appName>
MONGODB_DATABASE=trustgraph
JWT_SECRET=change-me-in-production
CLERK_SECRET_KEY=sk_test_your_key_here
CORS_ORIGIN=http://localhost:3000
# Public frontend URL — passport links, emails, Stripe redirects (no trailing slash)
FRONTEND_URL=http://localhost:3000

# Required for rich GitHub evidence (merged PR search, shadow seeding)
# Clerk GitHub login handles auth — this is for the GitHub API server-side
GITHUB_TOKEN=ghp_your_personal_access_token

# Pro billing (optional until you launch paid tier)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# Weekly digest emails (optional)
RESEND_API_KEY=re_...
EMAIL_FROM=TrustGraph <hello@yourdomain.com>

# Background refresh (daily GitHub, weekly SO + digest)
JOB_REFRESH_ENABLED=true

# AI profile enrichment — NVIDIA build.nvidia.com/z-ai/glm-5.1 (OpenAI-compatible)
# https://integrate.api.nvidia.com/v1
NVIDIA_AI_API=nvapi-...
NVIDIA_AI_MODEL=z-ai/glm-5.1
# Fallback when NVIDIA times out or is unavailable
GEMINI_API_KEY=
GEMINI_MODEL=gemma-4-31b-it
TAVILY_API_KEY=tvly-...
FIRECRAWL_API_KEY=fc-...

# Comma-separated GitHub usernames allowed to access /admin (default: rishicds)
ADMIN_GITHUB_USERS=rishicds
# Comma-separated emails with unlimited recruiter deep searches (no weekly/profile cooldown)
RECRUITER_UNLIMITED_EMAILS=rishipaulstudy@gmail.com
# Or fetch from gitstar-ranking: go run ./cmd/seed-shadows -gitstar -fetch-only -pages 10
SHADOW_GITHUB_FILE=data/shadow_github_users.txt
