{
    "designSystem": {
      "name": "Minimal SaaS Glassmorphism Lite",
      "version": "1.0",
      "category": "Modern B2B SaaS Landing Page",
      "keywords": [
        "minimal",
        "airy",
        "enterprise",
        "soft-glass",
        "premium",
        "high-trust",
        "grid-based",
        "rounded",
        "light-theme",
        "dashboard-inspired"
      ]
    },
  
    "visualLanguage": {
      "overallFeel": "Minimal, spacious, premium SaaS interface with subtle glassmorphism, soft gradients, large typography, and enterprise trust signals.",
      "personality": [
        "professional",
        "clean",
        "trustworthy",
        "modern",
        "lightweight",
        "approachable"
      ],
      "density": "low",
      "visualComplexity": "medium-low",
      "motionStyle": {
        "type": "soft",
        "duration": "200ms-500ms",
        "easing": "cubic-bezier(0.4, 0, 0.2, 1)"
      }
    },
  
    "colorSystem": {
      "background": {
        "primary": "#F5F5F5",
        "surface": "#FFFFFF",
        "surfaceSecondary": "#FAFAFA"
      },
  
      "text": {
        "primary": "#111111",
        "secondary": "#777777",
        "muted": "#A3A3A3"
      },
  
      "accent": {
        "primary": "#7BE13B",
        "primaryHover": "#68CB2E",
        "primarySoft": "#EAF8DD"
      },
  
      "secondaryAccent": {
        "teal": "#0F6E68",
        "tealLight": "#DFF5F1"
      },
  
      "borders": {
        "light": "#EAEAEA",
        "soft": "#F1F1F1"
      },
  
      "effects": {
        "glowGreen": "rgba(123,225,59,0.18)",
        "glowTeal": "rgba(15,110,104,0.12)",
        "shadow": "rgba(0,0,0,0.08)"
      }
    },
  
    "typography": {
      "fontFamily": {
        "primary": "Inter",
        "fallback": "system-ui, sans-serif"
      },
  
      "weights": {
        "regular": 400,
        "medium": 500,
        "semibold": 600,
        "bold": 700
      },
  
      "scale": {
        "hero": {
          "size": "72px-96px",
          "weight": 700,
          "lineHeight": 0.95
        },
  
        "sectionTitle": {
          "size": "42px-56px",
          "weight": 700,
          "lineHeight": 1.1
        },
  
        "cardTitle": {
          "size": "22px-28px",
          "weight": 600
        },
  
        "body": {
          "size": "16px-18px",
          "weight": 400,
          "lineHeight": 1.7
        },
  
        "caption": {
          "size": "13px-14px",
          "weight": 400
        }
      }
    },
  
    "spacingSystem": {
      "baseUnit": 8,
  
      "sectionSpacing": {
        "desktop": "120px-180px",
        "tablet": "80px-120px",
        "mobile": "60px-80px"
      },
  
      "containerPadding": {
        "desktop": "32px-48px",
        "tablet": "24px",
        "mobile": "20px"
      },
  
      "cardPadding": {
        "small": "20px",
        "medium": "28px",
        "large": "40px"
      }
    },
  
    "layout": {
      "containerWidth": "1280px-1440px",
  
      "grid": {
        "columns": 12,
        "gutter": "24px"
      },
  
      "structure": [
        "navbar",
        "hero",
        "social-proof",
        "about-section",
        "feature-grid",
        "integration-section",
        "pricing-section",
        "cta-banner",
        "footer"
      ],
  
      "alignment": {
        "hero": "center",
        "sections": "mixed",
        "cards": "left-aligned"
      }
    },
  
    "shapes": {
      "globalRadius": "24px",
      "cardRadius": "20px-28px",
      "buttonRadius": "12px-16px",
      "pillRadius": "999px",
  
      "style": [
        "soft-corners",
        "rounded-containers",
        "floating-elements"
      ]
    },
  
    "surfaces": {
      "cards": {
        "background": "#FFFFFF",
        "border": "1px solid #EAEAEA",
        "shadow": "0 10px 30px rgba(0,0,0,0.05)"
      },
  
      "glass": {
        "background": "rgba(255,255,255,0.75)",
        "backdropBlur": "10px-20px",
        "border": "1px solid rgba(255,255,255,0.5)"
      }
    },
  
    "backgroundEffects": {
      "gridPattern": {
        "enabled": true,
        "opacity": 0.06,
        "lineColor": "#111111"
      },
  
      "gradientGlow": {
        "enabled": true,
        "type": "radial",
        "colors": [
          "rgba(123,225,59,0.20)",
          "transparent"
        ]
      },
  
      "noise": {
        "enabled": false
      }
    },
  
    "buttons": {
      "primary": {
        "background": "#7BE13B",
        "text": "#111111",
        "radius": "14px",
        "padding": "14px 28px",
        "shadow": "0 10px 20px rgba(123,225,59,0.25)"
      },
  
      "secondary": {
        "background": "#111111",
        "text": "#FFFFFF",
        "radius": "14px"
      },
  
      "ghost": {
        "background": "transparent",
        "border": "1px solid #EAEAEA"
      }
    },
  
    "navigation": {
      "style": "floating-navbar",
      "position": "centered-top",
  
      "container": {
        "background": "#FFFFFF",
        "border": "1px solid #EAEAEA",
        "radius": "20px",
        "shadow": "0 8px 20px rgba(0,0,0,0.04)"
      },
  
      "links": {
        "weight": 500,
        "color": "#666666",
        "activeColor": "#111111"
      }
    },
  
    "heroSection": {
      "layout": "centered",
  
      "headline": {
        "maxWidth": "900px",
        "weight": 700,
        "multiLine": true
      },
  
      "description": {
        "maxWidth": "650px",
        "color": "#777777"
      },
  
      "ctaLayout": {
        "orientation": "horizontal",
        "gap": "12px"
      },
  
      "floatingElements": {
        "enabled": true,
        "style": [
          "mini-profile-cards",
          "status-badges",
          "small-dashboard-widgets"
        ],
        "shadow": "soft"
      }
    },
  
    "featureCards": {
      "layout": "3-column",
  
      "cardStyle": {
        "radius": "24px",
        "padding": "28px",
        "height": "uniform"
      },
  
      "variation": {
        "primaryCard": {
          "darkAccentBackground": true
        },
        "secondaryCards": {
          "lightTintBackground": true
        }
      },
  
      "contentHierarchy": [
        "title",
        "description",
        "visual-demo"
      ]
    },
  
    "statsBlocks": {
      "style": "minimal",
  
      "numbers": {
        "weight": 700,
        "size": "48px"
      },
  
      "decoration": {
        "cornerBrackets": true,
        "subtleGlow": true
      }
    },
  
    "integrationSection": {
      "layout": "center-focused",
  
      "visualPattern": {
        "type": "radial-ecosystem",
        "centerNode": true,
        "orbitingNodes": true
      },
  
      "background": {
        "softRadialGradient": true
      }
    },
  
    "pricing": {
      "layout": "2-column",
  
      "cards": {
        "radius": "20px",
        "elevation": "medium"
      },
  
      "featuredPlan": {
        "background": "#0F6E68",
        "text": "#FFFFFF",
        "accentButton": "#7BE13B"
      },
  
      "defaultPlan": {
        "background": "#FFFFFF",
        "border": "1px solid #EAEAEA"
      }
    },
  
    "footer": {
      "style": "minimal-enterprise",
  
      "layout": {
        "logoColumn": true,
        "multiLinkColumns": true,
        "newsletter": true
      },
  
      "background": "#FFFFFF",
      "borderTop": "1px solid #EAEAEA"
    },
  
    "componentPatterns": {
      "cards": [
        "profile-card",
        "stat-card",
        "feature-card",
        "pricing-card",
        "integration-node"
      ],
  
      "microComponents": [
        "avatar-group",
        "pill-badge",
        "floating-widget",
        "status-indicator",
        "soft-tag"
      ]
    },
  
    "shadowSystem": {
      "xs": "0 2px 8px rgba(0,0,0,0.04)",
      "sm": "0 8px 16px rgba(0,0,0,0.05)",
      "md": "0 12px 30px rgba(0,0,0,0.08)",
      "lg": "0 20px 40px rgba(0,0,0,0.12)"
    },
  
    "aiReplicationRules": [
      "Always use large amounts of whitespace.",
      "Prefer white surfaces over colored surfaces.",
      "Use one primary accent color and one supporting accent color.",
      "Keep borders subtle and visible.",
      "Use rounded corners everywhere.",
      "Combine soft gradients with grid backgrounds.",
      "Center hero content and surround it with floating UI fragments.",
      "Feature sections should use card-based layouts.",
      "Avoid heavy skeuomorphism or dark themes.",
      "Typography should carry most of the visual weight.",
      "Use glow effects sparingly.",
      "Favor enterprise SaaS aesthetics over startup playfulness.",
      "Every section should feel modular and reusable.",
      "Maintain a premium, uncluttered visual hierarchy."
    ]
  }